# ---- .NET / build output (regenerable, large: ~156 MB of WASM artifacts) ----
[Bb]in/
[Oo]bj/
*.user
*.suo
.vs/
artifacts/
project.lock.json
release/
# Stage 9: scratch dirs for local `dotnet publish` size/trim verification.
_sizetest_*/

# ---- Original Xbox 360 STFS package -------------------------------------------
# Provenance only: a 52 MB signed Xbox Live marketplace binary. The actual game
# assets are unpacked under extracted/ , so the package is not needed to build.
# Kept locally; re-extract from it only if you need to (see plans/plan.md appendix).
47D5BF15FF8CC1DB145E8BA9542C43FD3209A09A58

# ---- Stage-5 shader build artifacts ------------------------------------------
# Generated by tools/shaders/build_shaders.py. The source .fx (src/) and the
# script are committed; the compiled effect blobs ship under wwwroot/Content. The
# per-variant stubs and the MGCB response file are regenerated each build.
tools/shaders/gen/
tools/shaders/effects.mgcb

# ---- Claude Code local settings ----------------------------------------------
# Keep .claude/launch.json (used by the preview tooling); ignore machine-local bits.
.claude/settings.local.json
.claude/*.local.json
.claude/worktrees/

# ---- Python bytecode / scratch (tools/audio, tools/xnb, ...) -----------------
__pycache__/
*.pyc
tools/audio/_t2.ogg

# ---- Stage-12 custom-font build (tools/font/build_revenge_font.py) ------------
# The script + source sheets + overrides.json + the live editor + the built
# menufont ship. The _*.png are regenerated scrutiny/preview renders, data.json
# is re-emitted by `--emit-editor`, and *.orig are local pre-edit backups (the
# original font is already recoverable from git history).
tools/font/_*.png
tools/font/editor/data.json
*.orig
# Pre-shrink HD sprite backups (tools/upscale/shrink_sheet.py); local-only revert
# copies, so they never bloat the repo or the published site. The shrunk PNG ships.
*.png.hd4x
# Chroma-key preview composites (tools/help/key_help.py); scratch, the keyed PNG ships.
tools/help/preview/

# ---- Texture DXT build (tools/textures/build_dxt.py) -------------------------
# The script ships; the texconv.exe encoder is a ~1 MB Microsoft DirectXTex
# binary fetched locally (see the script header for the download URL), and
# _spike/ is scratch from manual encode/verify runs. The compiled .dds outputs
# DO ship (under wwwroot/Content), loaded by WebContentManager in preference to
# the .png.
tools/textures/texconv.exe
tools/textures/_*/

# ---- OS / editor cruft -------------------------------------------------------
Thumbs.db
desktop.ini
.DS_Store
*.swp
*.log

# ---- Raw asset sources / scratch ---------------------------------------------
# new_assets_raw/ holds raw AI-gen sprite sources + intermediate repacks (~68 MB).
# The SHIPPED assets live under wwwroot/Content; the repack scripts (tools/upscale/)
# reproduce the engine textures from these, so the raw gens are kept local-only.
new_assets_raw/
tools/tts/_alex_oneshot_full.mp3

# ---- Local secrets -----------------------------------------------------------
# tools/tts/*.py read ELEVENLABSTOKEN from .env; keep the token out of the repo.
.env
